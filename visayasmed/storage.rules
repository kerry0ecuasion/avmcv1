rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow admin uploads to any path
    match /doctors/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /slideshows/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /services/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /news/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Catch-all deny
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
